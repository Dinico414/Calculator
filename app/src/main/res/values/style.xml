<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="buttonRow">
        <item name="android:layout_weight">1</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">0dp</item>
    </style>

    <style name="buttonNumber">
        <item name="android:layout_weight">1</item>
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_marginHorizontal">5dp</item>
        <item name="android:background">@drawable/ripple_custom_button</item>
        <item name="backgroundTint">@color/secondaryContainer</item>
        <item name="android:textColor">@color/onSurface</item>
        <item name="android:textSize">30sp</item>
        <item name="android:onClick">numberAction</item>
        <item name="android:layout_marginVertical">5dp</item>
        <item name="android:padding">5dp</item>
<!--        <item name="android:stateListAnimator">@animator/button_pressed_anim</item>-->
        <item name="maxLines">1</item>
    </style>

    <style name="buttonOperator">
        <item name="android:layout_weight">1</item>
